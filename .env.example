# Endpoint HTTPS o ruta relativa para recibir el formulario de contacto
# Ejemplo cloud: https://api.tudominio.com/contact
# Ejemplo serverless en mismo dominio: /api/contact
VITE_CONTACT_ENDPOINT=

# Opcional: lista blanca de hosts permitidos para VITE_CONTACT_ENDPOINT
# Ejemplo: api.tudominio.com,forms.tudominio.com
VITE_ALLOWED_ENDPOINT_HOSTS=
